// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Store {
  id           Int       @id @default(autoincrement())
  shop         String    @unique
  installedAt  DateTime  @default(now())
  settings     Setting?
  decisions    Decision[]
}

model Setting {
  id                        Int      @id @default(autoincrement())
  store                     Store    @relation(fields: [storeId], references: [id])
  storeId                   Int      @unique
  feePct                    Float    @default(0)
  feeFixed                  Float    @default(0)
  windowDays                Int      @default(90)
  grossMarginThreshold      Float    @default(0.3)
  negativeOrderMarginAlert  Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model Decision {
  id                 Int              @id @default(autoincrement())
  store              Store            @relation(fields: [storeId], references: [id])
  storeId            Int
  type               String
  payloadJson        String
  recommendationJson String
  plannedAction      String?
  applied            Boolean          @default(false)
  expectedImpact     String?
  reviewDate         DateTime?
  status             String           @default("Pending")
  createdAt          DateTime         @default(now())
  createdBy          String?
  actions            DecisionAction[]
}

model DecisionAction {
  id           Int       @id @default(autoincrement())
  decision     Decision  @relation(fields: [decisionId], references: [id])
  decisionId   Int
  actionType   String
  notes        String?
  status       String   @default("Pending")
  reviewDate   DateTime?
  outcomeNotes String?
  updatedAt    DateTime @default(now())
}

model SkuCost {
  id        String   @id @default(cuid())
  shop      String
  sku       String
  title     String?
  cogsUnit  Float
  currency  String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([shop, sku])
  @@index([shop])
  @@index([sku])
}

// Variant-level COGS (persistent, per shop). Unique by (shop_id, variant_id).
model Cogs {
  id          String   @id @default(cuid())
  shopId      String
  variantId   String
  sku         String?
  cogsPerUnit Float
  currency    String?
  updatedAt   DateTime @updatedAt

  @@unique([shopId, variantId])
  @@index([shopId])
}

// Shop-level fee settings (one row per shop).
model ShopFeeSettings {
  shopId           String   @unique
  shopifyFeePct    Float    @default(0)
  gatewayFeePct    Float    @default(0)
  shippingCostPct  Float    @default(0)
  updatedAt        DateTime @updatedAt
}

// Webhook-synced shop record (idempotent, track uninstall).
model WebhookShop {
  id             String    @id @default(cuid())
  shopId         String    @unique // shop domain, e.g. store.myshopify.com
  uninstalledAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  orders         WebhookOrder[]
  lineItems      WebhookLineItem[]
  products       WebhookProduct[]
  variants       WebhookProductVariant[]
}

// Webhook-synced order (idempotent by shop_id + order_id).
model WebhookOrder {
  id              String   @id @default(cuid())
  shopId          String
  orderId         String   // Shopify order ID (GID or numeric string)
  totalPrice      String?
  subtotalPrice   String?
  totalTax        String?
  currency        String?
  financialStatus String?
  createdAt       DateTime? // order created_at from Shopify
  updatedAt      DateTime  @updatedAt
  shop            WebhookShop @relation(fields: [shopId], references: [shopId], onDelete: Cascade)
  lineItems       WebhookLineItem[]

  @@unique([shopId, orderId])
  @@index([shopId])
}

// Webhook-synced line item (idempotent by shop_id + line_item_id).
model WebhookLineItem {
  id             String   @id @default(cuid())
  shopId         String
  orderId        String
  lineItemId     String
  variantId      String?
  productId      String?
  sku            String?
  title          String?
  quantity       Int      @default(0)
  price          String?
  total          String?
  shop           WebhookShop @relation(fields: [shopId], references: [shopId], onDelete: Cascade)
  order          WebhookOrder @relation(fields: [shopId, orderId], references: [shopId, orderId], onDelete: Cascade)

  @@unique([shopId, lineItemId])
  @@index([shopId])
  @@index([shopId, orderId])
}

// Webhook-synced product (idempotent by shop_id + product_id).
model WebhookProduct {
  id         String   @id @default(cuid())
  shopId     String
  productId  String
  title      String?
  status     String?
  updatedAt  DateTime @updatedAt
  shop       WebhookShop @relation(fields: [shopId], references: [shopId], onDelete: Cascade)
  variants   WebhookProductVariant[]

  @@unique([shopId, productId])
  @@index([shopId])
}

// Webhook-synced variant (idempotent by shop_id + variant_id).
model WebhookProductVariant {
  id         String   @id @default(cuid())
  shopId     String
  variantId  String
  productId  String
  sku        String?
  title      String?
  price      String?
  status     String?
  updatedAt  DateTime @updatedAt
  shop       WebhookShop @relation(fields: [shopId], references: [shopId], onDelete: Cascade)
  product    WebhookProduct @relation(fields: [shopId, productId], references: [shopId, productId], onDelete: Cascade)

  @@unique([shopId, variantId])
  @@index([shopId])
  @@index([shopId, productId])
}
